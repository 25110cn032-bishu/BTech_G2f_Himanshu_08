#include <stdio.h>

int main() {
    int n, i, j;
    printf("Enter the size of the square matrix (n): ");
    scanf("%d", &n);

    int matrix[n][n];

    printf("Enter the elements of the matrix:\\n");
    for (i = 0; i < n; i++) {
        for (j = 0; j < n; j++) {
            scanf("%d", &matrix[i][j]);
        }
    }

    printf("\\nPrincipal Diagonal Elements: ");
    for (i = 0; i < n; i++) {
        // Condition for principal diagonal: i == j
        printf("%d ", matrix[i][i]);
    }

    return 0;
}
