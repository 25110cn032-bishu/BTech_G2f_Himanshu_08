#include <stdio.h>

int main() {
    int r, c, i, j;
    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &c);
    int matrix[r][c], transpose[c][r];

    // Input and Transpose Logic
    for (i = 0; i < r; ++i)
        for (j = 0; j < c; ++j) {
            printf("Element a%d%d: ", i + 1, j + 1);
            scanf("%d", &matrix[i][j]);
            transpose[j][i] = matrix[i][j];
        }

    // Display Transpose
    printf("Transpose Matrix:\n");
    for (i = 0; i < c; ++i) {
        for (j = 0; j < r; ++j) printf("%d ", transpose[i][j]);
        printf("\n");
    }
    return 0;
}
