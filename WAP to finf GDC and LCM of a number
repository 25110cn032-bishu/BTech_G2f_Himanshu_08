#include <stdio.h>

int main() {
    int num1, num2, a, b, temp, gcd, lcm;

    printf("Enter two positive integers: ");
    scanf("%d %d", &num1, &num2);

    a = num1;
    b = num2;

    // Calculate GCD using the Euclidean algorithm (while loop)
    while (b != 0) {
        temp = b;
        b = a % b;
        a = temp;
    }
    gcd = a;

    // Calculate LCM using the formula: LCM = (num1 * num2) / GCD
    lcm = (num1 * num2) / gcd;

    printf("The GCD of %d and %d is %d.\n", num1, num2, gcd);
    printf("The LCM of %d and %d is %d.\n", num1, num2, lcm);

    return 0;
}
