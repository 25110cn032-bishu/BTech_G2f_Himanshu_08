#include <stdio.h>

int main() {
    int n, i;
    float sum = 0.0, avg;

    // 1. Input number of elements
    printf("Enter the number of elements: ");
    scanf("%d", &n);

    float arr[n]; // Declaring array of size n

    // 2. Input array elements
    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; ++i) {
        printf("Element %d: ", i + 1);
        scanf("%f", &arr[i]);
        sum += arr[i]; // Calculating sum
    }

    // 3. Calculate average
    avg = sum / n;

    // 4. Output results
    printf("\nSum = %.2f\n", sum);
    printf("Average = %.2f\n", avg);

    return 0;
}
